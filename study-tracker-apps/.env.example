MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Email reminders (Resend) + Vercel Cron
# https://resend.com — create API key; verify a sending domain for production.
RESEND_API_KEY=
# Example: Study Tracker <reminders@yourdomain.com>
EMAIL_FROM=

# Bug reports from Settings (defaults to lukecoblentz.dev@gmail.com if unset)
# BUG_REPORT_EMAIL=

# Required in production (Vercel sets Authorization: Bearer CRON_SECRET on cron invocations)
CRON_SECRET=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; defaults to ${NEXTAUTH_URL}/api/google/callback
# GOOGLE_REDIRECT_URI=

# IANA timezone for interpreting due times (11:59 PM → all-day bar). Example: America/Los_Angeles
# CALENDAR_DEFAULT_TIMEZONE=America/New_York
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional override; defaults to ${NEXTAUTH_URL}/api/microsoft/callback
# MICROSOFT_REDIRECT_URI=
